# ─── Backend ───────────────────────────────────────────────────────────────────
# Local dev: point at your locally installed PostgreSQL
DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_db

# Change this before deploying to production!
JWT_SECRET=super-secret-jwt-key-change-in-production

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ─── Web (Next.js) ─────────────────────────────────────────────────────────────
# Used at build time by Next.js to proxy /api requests
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Mobile (Expo) ─────────────────────────────────────────────────────────────
# Must be your machine's LAN IP when testing on a physical device
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# ─── AWS (production only) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://lms_user:<password>@<rds-endpoint>:5432/lms_db
# JWT_SECRET=<strong-random-secret>
# CORS_ORIGINS=https://your-amplify-domain.amplifyapp.com
# NEXT_PUBLIC_API_URL=https://your-eb-endpoint.elasticbeanstalk.com
# EXPO_PUBLIC_API_URL=https://your-eb-endpoint.elasticbeanstalk.com
